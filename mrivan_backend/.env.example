PORT=3000

# Supabase Credentials (obtain from Settings > API in your Supabase Dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY_2=your-gemini-api-key-2

# AI Native API Key (obtain from AINative Studio)
AI_NATIVE_API_KEY=your-ai-native-api-key

# Groq API Key (obtain from Groq Console)
GROQ_API_KEY=your-groq-api-key

# OpenRouter API Key (obtain from OpenRouter Dashboard)
OPENROUTER_API_KEY=your-openrouter-api-key

# Nvidia NIM API Key (obtain from Nvidia build pipeline)
NVIDIA_API_KEY=your-nvidia-api-key

# Hugging Face Token (obtain from Hugging Face settings)
HF_TOKEN=your-huggingface-token

# Cloudflare API Token (obtain from Cloudflare dashboard)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Cloudinary Storage Configuration (Optional, for storing homework/documents)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
