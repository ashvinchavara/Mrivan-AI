PORT=3000

# Supabase Credentials (obtain from Settings > API in your Supabase Dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key

# AI Native API Key (obtain from AINative Studio)
AI_NATIVE_API_KEY=your-ai-native-api-key

# Cloudinary Storage Configuration (Optional, for storing homework/documents)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
